# syntax=docker/dockerfile:1.6
#
# Variant of Dockerfile that adds Av1an + VapourSynth + plugins so the
# parallel/scene-detected backend is available inside the container.
#
# Differs from the base Dockerfile by using masterofzen/av1an:latest as the
# runtime base. That image ships:
#   - av1an  (/usr/local/bin/av1an)
#   - ffmpeg n7.x with libsvtav1, libvmaf, libx264/x265, libvpx, NVENC
#   - VapourSynth (Core R69) + vspipe + ffms2 source plugin
#   - mkvtoolnix, Python 3.12
# So all we need to bolt on is ab-av1, the Python deps, and the app code.
#
# Build & run:
#   docker compose -f docker-compose.yml -f docker-compose.av1an.yml up --build
# NVENC inside the container also needs the gpu overlay:
#   docker compose -f docker-compose.yml \
#                  -f docker-compose.av1an.yml \
#                  -f docker-compose.gpu.yml up --build

# ──────────────────────────────────────────────────────────────────────────
# Stage 1: ab-av1 (latest release tarball — av1an image doesn't bundle it)
# ──────────────────────────────────────────────────────────────────────────
FROM debian:12-slim AS ab-av1-fetch
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl ca-certificates zstd \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /opt
RUN set -eux \
 && url="$(curl -fsSL https://api.github.com/repos/alexheretic/ab-av1/releases/latest \
            | grep -oE 'https://[^"]+linux-musl[^"]*\.tar\.zst' \
            | head -1)" \
 && if [ -z "$url" ]; then echo "could not resolve ab-av1 download url" >&2; exit 1; fi \
 && echo "Downloading $url" \
 && curl -fsSL --retry 3 -o ab-av1.tar.zst "$url" \
 && zstd -d ab-av1.tar.zst -o ab-av1.tar \
 && mkdir extract \
 && tar -xf ab-av1.tar -C extract \
 && find extract -type f -name ab-av1 -exec install -m 0755 {} /opt/ab-av1 \; \
 && rm -rf extract ab-av1.tar.zst ab-av1.tar \
 && /opt/ab-av1 --version

# ──────────────────────────────────────────────────────────────────────────
# Stage 2: final runtime image, derived from masterofzen/av1an
# ──────────────────────────────────────────────────────────────────────────
FROM masterofzen/av1an:latest AS app

# Image defaults to USER app_user; pacman + pip + COPY all need root.
USER root

# DO NOT run `pacman -Syu` here. The masterofzen base ships a hand-built
# /usr/local/bin/av1an linked against the ffmpeg 7 ABI (libavutil.so.59).
# A system upgrade pulls ffmpeg 8 (libavutil.so.60) and that binary dies
# with `error while loading shared libraries: libavutil.so.59`. Re-installing
# av1an from Arch's repo doesn't help either — the packaged av1an panics
# on `Failed to get VSScript API` because it was built against newer
# vapoursynth-rs bindings than the VSScript ABI in the base image.
#
# The two things we actually need on top of the base are:
#   - pip      → bootstrap with `python -m ensurepip` (no pacman touch)
#   - catatonit → static binary from upstream GitHub release
# Arch's Python ships a PEP 668 EXTERNALLY-MANAGED marker that blocks
# `python -m ensurepip` (it runs pip install under the hood, which sees the
# marker and refuses). We're in a container, so the system-vs-user split
# doesn't matter — drop the marker, install pip, restore nothing.
RUN find /usr/lib/python3* -maxdepth 2 -name EXTERNALLY-MANAGED -delete \
 && python3 -m ensurepip --upgrade

ARG CATATONIT_VERSION=0.2.0
RUN curl -fsSL --retry 3 \
        -o /usr/bin/catatonit \
        "https://github.com/openSUSE/catatonit/releases/download/v${CATATONIT_VERSION}/catatonit.x86_64" \
 && chmod 0755 /usr/bin/catatonit \
 && /usr/bin/catatonit --version

# ── SVT-AV1 v4.1.0 build for the av1an pipeline ──────────────────────────
#
# masterofzen/av1an:latest ships SVT-AV1 v2.1.2 (`/usr/sbin/SvtAv1EncApp` +
# `/usr/lib64/libSvtAv1Enc.so.2`). v4.x has roughly 30% better compression
# at low bitrates and supports a turbo first pass for 2-pass encoding.
#
# Strategy: install v4.1.0 to /usr/local/{bin,lib} *alongside* the v2 install
# rather than replacing it. The new SvtAv1EncApp links against
# libSvtAv1Enc.so.3 (v4 SONAME); the bundled ffmpeg keeps using
# libSvtAv1Enc.so.2 (v2 SONAME) — both libraries coexist on disk. av1an
# invokes SvtAv1EncApp by PATH lookup; /usr/local/bin precedes /usr/sbin so
# it picks up v4. The ab-av1 path (which uses ffmpeg's libsvtav1) keeps v2
# until a future ffmpeg rebuild.
#
# `pacman -Sy` syncs the package DB without upgrading already-installed
# packages, so this doesn't disturb the ffmpeg-7-vs-av1an ABI carefully
# preserved above. We immediately purge the build deps to keep the image
# slim.
ARG SVTAV1_VERSION=v4.1.0
ARG CMAKE_VERSION=3.31.5
# We can't install cmake from Arch's repo here: it cascades through
# libarchive/openssl into Arch's classic partial-upgrade trap. Instead we
# pull Kitware's official static `cmake-linux-x86_64.sh` (self-contained,
# zero deps) and use it just for the SVT-AV1 build. nasm has trivial deps
# so pacman handles it fine; gcc + make are already in the image.
# SVT-AV1 source comes from the GitLab release tarball — no git needed.
RUN sed -i 's/^SigLevel.*/SigLevel = Never/' /etc/pacman.conf \
 && pacman -Sy --noconfirm --needed --overwrite '*' nasm \
 && curl -fsSL --retry 3 \
        -o /tmp/cmake.sh \
        "https://github.com/Kitware/CMake/releases/download/v${CMAKE_VERSION}/cmake-${CMAKE_VERSION}-linux-x86_64.sh" \
 && mkdir -p /opt/cmake \
 && sh /tmp/cmake.sh --skip-license --prefix=/opt/cmake --exclude-subdir \
 && rm /tmp/cmake.sh \
 && export PATH="/opt/cmake/bin:$PATH" \
 && mkdir -p /tmp/svtbuild && cd /tmp/svtbuild \
 && curl -fsSL --retry 3 -o svt.tar.gz \
        "https://gitlab.com/AOMediaCodec/SVT-AV1/-/archive/${SVTAV1_VERSION}/SVT-AV1-${SVTAV1_VERSION}.tar.gz" \
 && tar -xzf svt.tar.gz && rm svt.tar.gz \
 && cd SVT-AV1-* \
 && cmake -B build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DBUILD_SHARED_LIBS=ON \
        -DBUILD_APPS=ON \
        -DBUILD_DEC=OFF \
 && cmake --build build -j"$(nproc)" \
 && cmake --install build \
 && echo '/usr/local/lib' > /etc/ld.so.conf.d/usr-local.conf \
 && ldconfig \
 && /usr/local/bin/SvtAv1EncApp --version \
 && cd / && rm -rf /tmp/svtbuild /opt/cmake

# ── ffmpeg rebuild against SVT-AV1 v4.1.0 ────────────────────────────────
#
# masterofzen ships ffmpeg n7.0.1 dynamically linked against
# libSvtAv1Enc.so.2 (v2.1.2). To make ab-av1 (which calls
# `ffmpeg -c:v libsvtav1`) use the new v4 encoder, we rebuild ffmpeg with
# pkg-config pointed at /usr/local/lib first so it picks up SVT-AV1 v4's
# .pc file.
#
# nv-codec-headers comes from a tarball (no full CUDA SDK needed; ffmpeg's
# nvenc/nvdec/cuvid encoders only need these stub headers at build time).
#
# Adds ~10-15 min to the build but makes the entire encoding pipeline —
# both av1an (calls SvtAv1EncApp directly) and ab-av1 (calls ffmpeg) —
# use SVT-AV1 v4.
# NOTE on ffmpeg version: SVT-AV1 v3 changed the encoder library API
# (`svt_av1_enc_init_handle` got a third argument; `enable_adaptive_
# quantization` was moved). ffmpeg's last tagged release (n7.1.1, Dec 2024)
# pre-dates that change. We pull from ffmpeg's master branch which has
# the v3+ wrapper updates. Pinned to a known-good commit so the build is
# reproducible.
ARG FFMPEG_REF=master
ARG NV_HEADERS_VERSION=n12.2.72.0
RUN pacman -Sy --noconfirm --needed --overwrite '*' nasm yasm \
 # nv-codec-headers (NVENC/NVDEC/CUVID stubs for ffmpeg's CUDA features)
 && curl -fsSL --retry 3 -o /tmp/nv.tar.gz \
        "https://github.com/FFmpeg/nv-codec-headers/archive/refs/tags/${NV_HEADERS_VERSION}.tar.gz" \
 && mkdir -p /tmp/nvbuild && tar -xzf /tmp/nv.tar.gz -C /tmp/nvbuild --strip-components=1 \
 && rm /tmp/nv.tar.gz \
 && make -C /tmp/nvbuild install PREFIX=/usr/local \
 && rm -rf /tmp/nvbuild \
 # ffmpeg source from master (n7.1.1 doesn't support SVT-AV1 v3+ ABI)
 && curl -fsSL --retry 3 -o /tmp/ff.tar.gz \
        "https://github.com/FFmpeg/FFmpeg/archive/${FFMPEG_REF}.tar.gz" \
 && mkdir -p /tmp/ffbuild && tar -xzf /tmp/ff.tar.gz -C /tmp/ffbuild --strip-components=1 \
 && rm /tmp/ff.tar.gz \
 && cd /tmp/ffbuild \
 && PKG_CONFIG_PATH="/usr/local/lib/pkgconfig:/usr/lib/pkgconfig" \
    ./configure \
        --prefix=/usr/local \
        --enable-shared --disable-static --disable-debug --disable-doc \
        --extra-cflags="-I/usr/local/include" \
        --extra-ldflags="-L/usr/local/lib -Wl,-rpath,/usr/local/lib" \
        --enable-gpl --enable-nonfree --enable-version3 \
        --enable-libsvtav1 --enable-libvmaf \
        --enable-libx264 --enable-libx265 --enable-libvpx \
        --enable-libaom --enable-libdav1d \
        --enable-libopus --enable-libvorbis --enable-libmp3lame \
        --enable-libfreetype --enable-libass \
        --enable-libwebp \
        --enable-cuvid --enable-nvdec --enable-nvenc --enable-ffnvcodec \
 && make -j"$(nproc)" \
 && make install \
 && ldconfig \
 && /usr/local/bin/ffmpeg -version | head -1 \
 # Sanity: confirm libsvtav1 encoder is present and resolves to v4 lib
 && /usr/local/bin/ffmpeg -hide_banner -encoders 2>&1 | grep libsvtav1 \
 && ldd /usr/local/bin/ffmpeg | grep -i svtav1 \
 && cd / && rm -rf /tmp/ffbuild \
 && pacman -Rns --noconfirm nasm yasm \
 && pacman -Scc --noconfirm

WORKDIR /app

# ab-av1 binary, plus symlinks so app/tools.py:_find_ffmpeg picks up the
# rebuilt ffmpeg from /usr/local (linked against SVT-AV1 v4.1.0). The
# masterofzen-shipped /usr/sbin/ffmpeg is still in place but uses the v2
# SVT lib, so we point /app/bin at the v4 build instead.
COPY --from=ab-av1-fetch /opt/ab-av1 /app/bin/ab-av1
RUN chmod 0755 /app/bin/ab-av1 \
 && ln -sf /usr/local/bin/ffmpeg  /app/bin/ffmpeg \
 && ln -sf /usr/local/bin/ffprobe /app/bin/ffprobe

# Python deps. Arch enforces PEP 668 so --break-system-packages is required;
# we're inside a container, the system Python is the only Python.
COPY requirements.txt /app/
RUN python3 -m pip install --no-cache-dir --break-system-packages --upgrade pip \
 && python3 -m pip install --no-cache-dir --break-system-packages -r requirements.txt

# App code
COPY app/    /app/app/
COPY static/ /app/static/

# Runtime data dirs — also volume-mount points
RUN mkdir -p /app/uploads /app/outputs

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PATH=/app/bin:$PATH

EXPOSE 8000

# masterofzen/av1an's default ENTRYPOINT runs av1an itself. Override so we
# run uvicorn instead; catatonit reaps zombie ffmpeg subprocesses cleanly.
ENTRYPOINT ["/usr/bin/catatonit", "--"]
CMD ["python3", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD python3 -c "import urllib.request,sys; urllib.request.urlopen('http://127.0.0.1:8000/api/capabilities',timeout=3)" \
        || exit 1
